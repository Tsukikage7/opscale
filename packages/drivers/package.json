{
  "name": "opscale-drivers",
  "version": "0.1.0",
  "description": "Node.js database drivers for Opscale.",
  "license": "MIT",
  "keywords": [
    "opscale",
    "sql",
    "database",
    "postgres",
    "mysql",
    "sqlite",
    "sqlserver"
  ],
  "homepage": "https://github.com/Tsukikage7/opscale#readme",
  "bugs": {
    "url": "https://github.com/Tsukikage7/opscale/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tsukikage7/opscale.git",
    "directory": "packages/drivers"
  },
  "type": "module",
  "files": [
    "dist/src",
    "README.md"
  ],
  "exports": {
    ".": "./dist/src/index.js"
  },
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/test/*.test.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "opscale-core": "workspace:*",
    "mssql": "^12.5.4",
    "mysql2": "^3.15.3",
    "pg": "^8.16.3",
    "sql.js": "^1.13.0"
  },
  "devDependencies": {
    "@types/mssql": "^12.3.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.6",
    "@types/sql.js": "^1.4.9",
    "typescript": "^5.9.0"
  }
}
